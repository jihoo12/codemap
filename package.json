{
  "name": "codemap",
  "version": "1.0.0",
  "description": "Generate interactive visual maps of your codebase as a single self-contained HTML file",
  "type": "module",
  "bin": {
    "codemap": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && cp template/template.html dist/template.html",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "codebase",
    "visualization",
    "dependency-graph",
    "code-map",
    "architecture",
    "diagram"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@types/node": "^26.1.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "shiki": "^4.3.1",
    "typescript": "^7.0.2"
  },
  "devDependencies": {
    "jsdom": "^29.1.1"
  }
}
